{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Platform Policy Profile",
  "description": "Maps platform-specific content policies to the universal harm taxonomy.",
  "type": "object",
  "required": ["platform", "version", "policy_url", "categories"],
  "properties": {
    "platform": { "type": "string" },
    "version": { "type": "string" },
    "policy_url": { "type": "string", "format": "uri" },
    "last_updated": { "type": "string", "format": "date" },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["maps_to", "policy_action"],
        "properties": {
          "maps_to": { "type": "string", "description": "Canonical harm category ID" },
          "policy_action": { "type": "string", "enum": ["allow", "flag_for_review", "remove", "remove_and_escalate"] },
          "severity_override": { "type": "string", "enum": ["benign", "borderline", "severe", "critical"] },
          "notes": { "type": "string" },
          "platform_specific_context": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
